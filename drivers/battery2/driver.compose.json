{
  "name": {
    "en": "Battery",
    "nl": "Batterij"
  },
  "class": "battery",
  "capabilities": [
    "measure_power",
    "measure_battery",
    "battery_charging_state",
    "charge_setpoint"
  ],
  "capabilitiesOptions": {
    "meter_power.charged": {
      "title": {
        "en": "Charged energy",
        "nl": "Geladen energie"
      },
      "decimals": 2
    },
    "meter_power.discharged": {
      "title": {
        "en": "Discharged energy",
        "nl": "Ontladen energie"
      },
      "decimals": 2
    },
    "dim.active_power": {
      "title": {
        "en": "Maximum AC power",
        "nl": "Maximaal AC vermogen"
      },
      "uiComponent": "slider"
    }
  },
  "energy": {
    "homeBattery": true,
    "meterPowerImportedCapability": "meter_power.charged",
    "meterPowerExportedCapability": "meter_power.discharged"
  },
  "platforms": [
    "local",
    "cloud"
  ],
  "connectivity": ["cloud"],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "login_credentials",
      "template": "login_credentials",
      "options": {
        "title": {
          "en": "Get your API token in the ShinePhone app"
        },
        "usernameLabel": { "en": "Username", "nl": "Gebruikersnaam" },
        "passwordLabel": { "en": "API Token", "nl": "API Token" },
        "passwordPlaceholder": { "en": "My account>User name>API Token" },
        "logo": "../assets/images/small.png"
      }
    },
		{
			"id": "list_devices",
			"template": "list_devices",
			"navigation": {
				"next": "add_devices"
			}
		},
		{
			"id": "add_devices",
			"template": "add_devices"
		}
	]
}