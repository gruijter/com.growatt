{
  "name": {
    "en": "Solar inverter",
    "nl": "PV omvormer"
  },
  "class": "solarpanel",
  "capabilities": [
    "measure_power",
    "meter_power",
    "meter_power.today",
    "target_power"
  ],
  "capabilitiesOptions": {
    "meter_power.today": {
      "title": {
        "en": "Energy today",
        "nl": "Energie vandaag"
      }
    },
    "measure_power": {
      "title": {
        "en": "Solar Power (AC)",
        "nl": "Zonne-energie (AC)"
      },
      "decimals": 0
    },
    "measure_power.dc_solar": {
      "title": {
        "en": "Solar Power (DC)",
        "nl": "Zonne-energie (DC)"
      },
      "decimals": 0
    },
    "measure_power.ac_inverter": {
      "title": {
        "en": "Inverter Power (AC)",
        "nl": "Omvormer vermogen (AC)"
      },
      "decimals": 0
    },
    "target_power": {
      "decimals": 0
    }
  },
  "platforms": [
    "local",
    "cloud"
  ],
  "connectivity": ["cloud"],
  "images": {
    "small": "{{driverAssetsPath}}/images/small.png",
    "large": "{{driverAssetsPath}}/images/large.png",
    "xlarge": "{{driverAssetsPath}}/images/xlarge.png"
  },
  "pair": [
    {
      "id": "login_credentials",
      "template": "login_credentials",
      "options": {
        "title": {
          "en": "Get your API token in the ShinePhone app"
        },
        "usernameLabel": { "en": "Username", "nl": "Gebruikersnaam" },
        "passwordLabel": { "en": "API Token", "nl": "API Token" },
        "passwordPlaceholder": { "en": "My account>User name>API Token" },
        "logo": "../assets/images/small.png"
      }
    },
		{
			"id": "list_devices",
			"template": "list_devices",
			"navigation": {
				"next": "add_devices"
			}
		},
		{
			"id": "add_devices",
			"template": "add_devices"
		}
	]
}