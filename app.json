  "flow": {
    "triggers": [
      {
        "title": {
          "en": "AC power limit changed",
          "nl": "AC vermogensbeperking is gewijzigd"
        },
        "highlight": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=inverter2&capabilities=dim.active_power"
          }
        ],
        "tokens": [
          {
            "name": "dim.active_power",
            "type": "number",
            "title": {
              "en": "Limit level",
              "nl": "Begrenzingsniveau"
            },
            "example": 53
          }
        ],
        "id": "dim.active_power_changed"
      },
      {
        "title": {
          "en": "Inverter power (AC) changed",
          "nl": "Omvormer vermogen (AC) is gewijzigd"
        },
        "highlight": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=measure_power.ac_inverter"
          }
        ],
        "tokens": [
          {
            "name": "measure_power.ac_inverter",
            "type": "number",
            "title": {
              "en": "Inverter power (AC)",
              "nl": "Omvormer vermogen (AC)"
            },
            "example": 1450
          }
        ],
        "id": "measure_power.ac_inverter_changed"
      },
      {
        "title": {
          "en": "Solar power (DC) changed",
          "nl": "Zonne-energie (DC) is gewijzigd"
        },
        "highlight": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=measure_power.dc_solar"
          }
        ],
        "tokens": [
          {
            "name": "measure_power.dc_solar",
            "type": "number",
            "title": {
              "en": "Solar power (DC)",
              "nl": "Zonne-energie (DC)"
            },
            "example": 1500
          }
        ],
        "id": "measure_power.dc_solar_changed"
      },
      {
        "title": {
          "en": "Energy today changed",
          "nl": "Energie vandaag is gewijzigd"
        },
        "highlight": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "capabilities=meter_power.today"
          }
        ],
        "tokens": [
          {
            "name": "meter_power.today",
            "type": "number",
            "title": {
              "en": "Energy today",
              "nl": "Energie vandaag"
            },
            "example": 12.5
          }
        ],
        "id": "meter_power.today_changed"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Limit AC power",
          "nl": "Beperk AC vermogen"
        },
        "titleFormatted": {
          "en": "Limit inverter AC power to [[val]]",
          "nl": "Begrens omvormer AC vermogen naar [[val]]"
        },
        "highlight": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=inverter2&capabilities=dim.active_power"
          },
          {
            "name": "val",
            "type": "range",
            "title": {
              "en": "Limit",
              "nl": "Limiet"
            },
            "min": 0,
            "max": 1,
            "step": 0.01,
            "value": 1,
            "label": "%",
            "labelMultiplier": 100,
            "labelDecimals": 0
          }
        ],
        "id": "dim.active_power"
      },
      {
        "title": {
          "en": "Get status update",
          "nl": "Haal status update op"
        },
        "hint": {
          "en": "This will try to update the status of all devices immediately. Carefull: too many updates will cause the server to temporarily block you.",
          "nl": "Dit zal proberen de status van alle apparaten onmiddellijk bij te werken. Let op: te veel updates zullen ervoor zorgen dat de server je tijdelijk blokkeert."
        },
        "id": "force_poll"
      }
    ]
  },
