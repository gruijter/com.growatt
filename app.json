  "flow": {
    "triggers": [
      {
        "title": {
          "en": "The curtailment level changed",
          "nl": "Het begrenzingsniveau is gewijzigd"
        },
        "highlight": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=inverter|battery&capabilities=dim.active_power"
          }
        ],
        "tokens": [
          {
            "name": "dim.active_power",
            "type": "number",
            "title": {
              "en": "Curtailment level",
              "nl": "Begrenzingsniveau"
            },
            "example": 53
          }
        ],
        "id": "dim.active_power_changed"
      }
    ],
    "actions": [
      {
        "title": {
          "en": "Power curtailment",
          "nl": "Vermogen begrenzing"
        },
        "titleFormatted": {
          "en": "Limit inverter power to [[val]]",
          "nl": "Begrens omvormer vermogen naar [[val]]"
        },
        "highlight": true,
        "args": [
          {
            "type": "device",
            "name": "device",
            "filter": "driver_id=inverter&capabilities=dim.active_power"
          },
          {
            "name": "val",
            "type": "range",
            "title": {
              "en": "Curtailment level",
              "nl": "Begrenzingsniveau"
            },
            "min": 0,
            "max": 1,
            "step": 0.01,
            "value": 1,
            "label": "%",
            "labelMultiplier": 100,
            "labelDecimals": 0
          }
        ],
        "id": "dim.active_power"
      },
      {
        "title": {
          "en": "Get status update",
          "nl": "Haal status update op"
        },
        "hint": {
          "en": "This will try to update the status of all devices immediately. Carefull: too many updates will cause the server to temporarily block you.",
          "nl": "Dit zal proberen de status van alle apparaten onmiddellijk bij te werken. Let op: te veel updates zullen ervoor zorgen dat de server je tijdelijk blokkeert."
        },
        "id": "force_poll"
      }
    ]
  },
